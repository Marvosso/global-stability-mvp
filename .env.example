# App URL (alert emails, ingest scripts). Production: https://geostability.com
NEXT_PUBLIC_APP_URL=https://geostability.com
# For ingest scripts and cron; defaults to NEXT_PUBLIC_APP_URL or localhost
# APP_BASE_URL=https://geostability.com
# INGEST_BASE_URL=https://geostability.com

# Supabase (browser auth)
# Do not commit real keys. Copy to .env.local and fill in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin access (temporary bypass if auth redirect loop blocks you)
# DISABLE_ADMIN_AUTH=true — middleware allows /admin without login (server-side)
# NEXT_PUBLIC_DISABLE_ADMIN_AUTH=true — AdminGuard skips session/role check (client-side; set both to fully bypass)
# ADMIN_ALLOW_USER_IDS=uuid1,uuid2 — allow these Supabase user IDs in middleware even without app_metadata role
# NEXT_PUBLIC_ADMIN_ALLOW_USER_IDS=uuid1,uuid2 — same allowlist for client-side AdminGuard
# DISABLE_ADMIN_AUTH=
# NEXT_PUBLIC_DISABLE_ADMIN_AUTH=
# ADMIN_ALLOW_USER_IDS=
# NEXT_PUBLIC_ADMIN_ALLOW_USER_IDS=

# Mapbox (public map and server-side reverse geocoding for country_code)
NEXT_PUBLIC_MAPBOX_TOKEN=
# Optional: use a separate token for server-side geocoding; falls back to NEXT_PUBLIC_MAPBOX_TOKEN
# MAPBOX_ACCESS_TOKEN=

# ReliefWeb v2 API (required for cron/run-feed and ingest:reliefweb). Use your approved appname from ReliefWeb.
RELIEFWEB_APPNAME=

# Ingest API (scripts: ingest:gdelt, ingest:firms, etc.)
INGEST_API_KEY=

# NASA FIRMS (wildfire ingest). Get a key: https://firms.modaps.eosdis.nasa.gov/api/map_key
# Use FIRMS_MAP_KEY or FIRMS_API_KEY in .env.local
FIRMS_MAP_KEY=

# ACLED (conflict events: Ukraine, Israel, Iran). Use myACLED email + password (OAuth; no API key).
# Optional: ACLED_EMAIL_ADDRESS or email_address / acled_password (same as acledR).
ACLED_EMAIL=
ACLED_PASSWORD=

# OpenAI (AI context draft generation – Phase 12A)
OPENAI_API_KEY=
# Optional: model override (default: gpt-4o-mini)
# OPENAI_MODEL=
